{
  "version": 1,
  "description": "Imaging-only: camera, beam, noise, PSF, display. Optional batch (seeds, figure_paths, ...); with split configs, len(seeds) must match dynamics JSON batch.dynamics_overrides. Pair with example_dynamics.json.",
  "camera": {
    "pixel_um": 0.25,
    "l": 1024,
    "h": 256,
    "x0_um": 0.0,
    "y0_um": 0.0
  },
  "beam": {
    "w_um": 500.0,
    "xb_um": 0.0,
    "yb_um": 0.0,
    "I": 10000
  },
  "noise": {
    "shot_factor": 1,
    "shot_scale": 1e10,
    "readout_factor": 1e7,
    "readout_sigma": 1.0,
    "bg_offset": 0.0,
    "seed": 42
  },
  "imaging": {
    "psf_sigma_px": 2.0,
    "normalize_mode": "max",
    "normalize_eps": 1e-12,
    "normalize_q_low": 0.1,
    "normalize_q_high": 99.9,
    "normalize_q_scale": 99.9
  },
  "simulation": {
    "apply_sensor_noise": true
  },
  "display": {
    "show": false,
    "show_block": true,
    "figure_path": null,
    "show_title": "Ion image (simulation)"
  },
  "batch": {
    "seeds": [1001, 1002, 1003, 1004, 1005],
    "max_workers": 1
  }
}
